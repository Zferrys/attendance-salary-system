<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
    Web应用部署描述符 (web.xml)
    Servlet版本: 3.1 (兼容 Tomcat 8+)
    
    用途: 配置Web应用的全局行为，包括：
          - 欢迎页面
          - Servlet映射
          - 过滤器配置
          - 错误页面
          - 字符编码设置
============================================================ -->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- ==================== 欢迎页面（默认首页） ==================== -->
    <welcome-file-list>
        <welcome-file>views/common/login.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== 编码过滤器（解决中文乱码） ==================== -->
    <filter>
        <filter-name>encodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>encodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== 错误页面配置 ==================== -->

    <!-- 403访问被拒绝 -->
    <error-page>
        <error-code>403</error-code>
        <location>/views/common/error_403.jsp</location>
    </error-page>

    <!-- 404页面未找到 -->
    <error-page>
        <error-code>404</error-code>
        <location>/views/common/error_404.jsp</location>
    </error-page>

    <!-- 500服务器内部错误 -->
    <error-page>
        <error-code>500</error-code>
        <location>/views/common/error_500.jsp</location>
    </error-page>

</web-app>
